{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetfree.local/contracts/summary-contract.v0.1.0.schema.json",
  "title": "Summary Contract v0.1.0",
  "description": "Canonical meeting summary payload contract.",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": 1
        },
        "contract_version": {
          "const": "v0.1.0"
        },
        "format": {
          "const": "markdown"
        },
        "markdown": {
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "contract_version",
        "format",
        "markdown"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": 1
        },
        "contract_version": {
          "const": "v0.1.0"
        },
        "format": {
          "const": "blocknote"
        },
        "markdown": {
          "type": "string"
        },
        "summary_json": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blocknoteBlock"
          }
        }
      },
      "required": [
        "schema_version",
        "contract_version",
        "format",
        "markdown",
        "summary_json"
      ],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "blocknoteBlock": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "content": {
          "type": "array"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blocknoteBlock"
          }
        }
      },
      "required": [
        "id",
        "type"
      ],
      "additionalProperties": true
    }
  }
}
